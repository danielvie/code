@prefix : <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

:Alice a foaf:Person ;
       foaf:name "Alice" ;
       foaf:knows :Bob ;
       :owns :TeddyBear, :RubiksCube, :Laptop, :DinosaurModel, :Bicycle, :LegoSet, :WaterBottle .

:Bob a foaf:Person ;
     foaf:name "Bob" .

# Definitions for items
:TeddyBear a :Toy .
:RubiksCube a :Toy .
:Laptop a :Electronics .
:DinosaurModel a :Toy .
:Bicycle a :Vehicle .
:LegoSet a :Toy .
:WaterBottle a :Utility .
