// Zed settings
{
  // =====================
  // UI & APPEARANCE
  // =====================
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  },
  "theme_overrides": {
    "One Dark Pro": {
      "border.variant": "#15181c",
      "border": "#404754",
      "syntax": {
        "comment": {
          "font_style": "italic"
        }
      }
    }
  },
  "icon_theme": "Warm Charmed Icons",
  "colorize_brackets": true,
  "ui_font_size": 18.0,
  
  // =====================
  // EDITOR & BUFFER
  // =====================
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15.0,
  "buffer_font_features": {
    "calt": true
  },
  "buffer_line_height": {
    "custom": 2
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "diff_view_style": "split",
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "inlay_hints": {
    "show_value_hints": true,
  },

  // =====================
  // PANELS & DOCKING
  // =====================
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "project_panel": {
    "dock": "left"
  },
  "title_bar": {
    "show_onboarding_banner": false
  },

  // =====================
  // TERMINAL
  // =====================
  "experimental.theme_overrides": {
    "terminal.ansi.blue": "#1c6974",
    "terminal.ansi.bright_blue": "#ff0000",
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "toolbar": {
      "breadcrumbs": true
    },
    "shell": {
      "with_arguments": {
        "program": "pwsh.exe",
        "args": ["-nologo"],
        "title_override": "terminal"
      }
    }
  },

  // =====================
  // AI & AGENTS
  // =====================
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.5",
      "enable_thinking": false
    },
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "always_confirm": [
            {
              "pattern": "^rm\\b"
            }
          ]
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.6"
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.5",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-haiku-4-5",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-haiku-4.5",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "xiaomi/mimo-v2-pro",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openai/gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "minimax/minimax-m2.7",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "z-ai/glm-5.1",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "qwen/qwen3.6-plus",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openai/gpt-5.3-codex",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.6",
        "enable_thinking": true
      }
    ],
    "model_parameters": []
  },
  "agent_buffer_font_size": 17,
  "language_models": {
    "openai_compatible": {
      "Fireworks": {
        "api_url": "https://api.fireworks.ai/inference/v1",
        "available_models": [
          {
            "name": "accounts/fireworks/models/kimi-k2p6",
            "display_name": "Kimi k2.6 (fireworks.ai)",
            "max_tokens": 262000
          }, 
          {
            "name": "accounts/fireworks/models/kimi-k2p5",
            "display_name": "Kimi k2.5 (fireworks.ai)",
            "max_tokens": 262000
          }
        ]
      }
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "open_ai_compatible_api": {
      "api_url": "http://localhost:11434/v1/completions",
      "model": "deepseek-coder:6.7b",
      "prompt_format": "infer",
      "max_output_tokens": 64
    }
  },

  // =====================
  // LANGUAGE SERVERS (LSP)
  // =====================
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "on"
    },
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server"
      ]
    },
    "C": {
      "format_on_save": "off"
    },
    "C++": {
      "format_on_save": "off"
    },
    "PowerShell": {
      "format_on_save": "off"
    },
    "LaTeX": {
      "format_on_save": "off"
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": true,
            "forwardSearchAfter": true
          },
          "forwardSearch": {
            "executable": "SumatraPDF.exe",
            "args": [
              "-reuse-instance",
              "%p",
              "-forward-search",
              "%f",
              "%l"
            ]
          }
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"]
        }
      }
    },
    "matlab-language-server": {
      "settings": {
        "installPath": "C:/Program Files/MATLAB/R2024a",
        "indexWorkspace": true,
        "matlabConnectionTiming": "onStart",
        "telemetry": false
      }
    },
    "clangd": {
      "initialization_options": {
        "fallbackFlags": ["-I", "main/include"],
        "compilation_databasePath": "build"
      },
      "binary": {
        "arguments": ["--header-insertion=never"]
      }
    }
  },

  // =====================
  // MCP
  // =====================
  // "context_servers": {
  //   "agentation": {
  //     "command": "npx",
  //     // "args": ["-y", "agentation-mcp", "server"]
  //     "args": ["agentation-mcp", "server"]
  //   }
  // },
  
  // =====================
  // OTHER
  // =====================
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    }
  },
}
