// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // --- UI and Appearance ---
  "git_panel": {
    "tree_view": true
  },
  "agent_servers": {
    
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  },
  "icon_theme": "Warm Charmed Icons",
  "colorize_brackets": true,
  "ui_font_size": 18.0,
  "buffer_font_size": 15.0,
  "buffer_font_features": { // ligatures
    "calt": true
  },
  "theme_overrides": {
    "One Dark Pro": {
      "border.variant": "#15181c",
      "border": "#15181c",
      // "players": [
      //   {
      //     "cursor": "#ae68ff",
      //   }
      // ],
      "syntax": {
        "comment": {
          "font_style": "italic"
        }
      }
    }
  },
  "title_bar": {
    "show_onboarding_banner": false,
    // "show_sign_in": false,
  },
  "project_panel": {
    "dock": "left"
  },
  "buffer_line_height": {
    "custom": 2,
  },
  "agent_buffer_font_size": 17,
  // "agent_ui_font_size": 20,

  // --- Editor and Behavior ---
  "vim_mode": true,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  
  "experimental.theme_overrides": {
    "terminal.ansi.blue": "#297F96",
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "toolbar": {
      "breadcrumbs": true,
    },
    "shell": {
      "with_arguments": {
        "program": "pwsh.exe",
        "args": ["-nologo"],
        "title_override": "terminal",
      },
    },
  },

  // --- AI and Language Models ---
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "always_confirm": [
            {
              "pattern": "^rm\\b"
            },
          ]
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.5"
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.5",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-haiku-4-5",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-haiku-4.5",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "xiaomi/mimo-v2-pro",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openai/gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "open_ai_compatible_api": {
      "api_url": "http://localhost:11434/v1/completions",
      "model": "deepseek-coder:6.7b",
      "prompt_format": "infer",
      "max_output_tokens": 64
    }
  },

  // --- Languages ---
  "languages": {
    "Python": {
      "language_servers": [
        "pyright",
        "ruff"
      ],
      "format_on_save": "on"
    },
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server"
      ]
    },
    "C": {
      "format_on_save": "off"
    },
    "C++": {
      "format_on_save": "off"
    },
    "PowerShell": {
      "format_on_save": "off"
    },
    "LaTeX": {
      "format_on_save": "off"
    }
  },

  // --- LSP Configuration ---
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": true,
            "forwardSearchAfter": true
          },
          "forwardSearch": {
            "executable": "SumatraPDF.exe",
            "args": [
              "-reuse-instance",
              "%p",
              "-forward-search",
              "%f",
              "%l"
            ]
          }
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": [
          "cva",
          "cx"
        ],
        "experimental": {
          "classRegex": [
            "[cls|className]\\s\\:\\=\\s\"([^\"]*)"
          ]
        }
      }
    },
    "matlab-language-server": {
      "settings": {
        "installPath": "C:/Program Files/MATLAB/R2024a",
        "indexWorkspace": true,
        "matlabConnectionTiming": "onStart",
        "telemetry": false
      }
    },
    "clangd": {
      "initialization_options": {
        "fallbackFlags": [
          "-I",
          "main/include"
        ],
        "compilation_databasePath": "build"
      },
      "binary": {
        "arguments": [
          "--header-insertion=never"
        ]
      }
    }
  },
}
